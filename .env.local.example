# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Automation Adapter (Make/n8n webhook URL)
AUTOMATION_WEBHOOK_URL=https://hook.make.com/your-webhook-id

# OpenAI (for AI agents)
OPENAI_API_KEY=sk-your-openai-key

# Zoom API (for meeting scheduling)
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS=path-to-credentials.json

# Miro
MIRO_ACCESS_TOKEN=your-miro-token
MIRO_BOARD_ID=your-board-id

# Monday CRM
MONDAY_API_KEY=your-monday-api-key
MONDAY_BOARD_ID=your-monday-board-id
